includes:
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon
    - vendor/tomasvotruba/type-coverage/config/extension.neon

parameters:
    level: max
    paths:
        - src
        - tests

    type_coverage:
        return: 80
        param: 80
        property: 80
        constant: 80
        declare: 100
